<Window x:Class="Level_2026.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Level 2026"
        Height="850"
        Width="1400"
        Background="#F5F5F5">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP BAR ================= -->
        <DockPanel Grid.Row="0" Background="#EAEAEA" Margin="5">

            <!-- NAV -->
            <StackPanel Orientation="Horizontal">

                <Button Content="Input"
                        Width="120"
                        Margin="5"
                        Click="ShowInput_Click"/>

                <Button Content="Compensazione"
                        Width="160"
                        Margin="5"
                        Click="ShowComp_Click"/>

            </StackPanel>

            <!-- PESI -->
            <StackPanel Orientation="Horizontal" Margin="30,0,0,0">

                <TextBlock Text="Pesi:"
                           VerticalAlignment="Center"
                           FontWeight="Bold"/>

                <RadioButton x:Name="rbConst"
                             Content="1"
                             Margin="10,0"
                             IsChecked="True"/>

                <RadioButton x:Name="rbInvD"
                             Content="1/d"
                             Margin="10,0"/>

                <RadioButton x:Name="rbInvD2"
                             Content="1/d²"/>

            </StackPanel>

        </DockPanel>

        <!-- ================= MAIN AREA ================= -->
        <Grid Grid.Row="1">

            <!-- ================= INPUT ================= -->
            <Grid x:Name="GridInput">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT PANEL -->
                <StackPanel Grid.Column="0" Margin="10">

                    <!-- FILE -->
                    <GroupBox Header="File">
                        <StackPanel>

                            <Button Content="Carica Excel"
                                    Height="35"
                                    Margin="5"
                                    Click="Carica_Click"/>

                        </StackPanel>
                    </GroupBox>

                    <!-- CAPISALDI -->
                    <GroupBox Header="Capisaldi fissati" Margin="0,10,0,0">

                        <StackPanel>

                            <ListBox x:Name="ListNodes"
                                     Height="120"/>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">

                                <TextBox x:Name="TxtQuota"
                                         Width="90"
                                         Margin="0,0,5,0"/>

                                <Button Content="Aggiungi"
                                        Click="AddFixed_Click"/>

                                <Button Content="Rimuovi"
                                        Margin="5,0,0,0"
                                        Click="RemoveFixed_Click"/>

                            </StackPanel>

                            <DataGrid x:Name="GridFixed"
                                      Height="150"
                                      AutoGenerateColumns="False">

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Nodo" Binding="{Binding Key}" Width="*"/>
                                    <DataGridTextColumn Header="Quota" Binding="{Binding Value}" Width="*"/>
                                </DataGrid.Columns>

                            </DataGrid>

                        </StackPanel>

                    </GroupBox>

                    <!-- RUN -->
                    <Button Content="Esegui compensazione"
                            Height="40"
                            Margin="0,15,0,0"
                            Click="Compensa_Click"/>

                </StackPanel>

                <!-- RIGHT PANEL -->
                <Grid Grid.Column="1" Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="3*"/>
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <!-- RETE -->
                    <GroupBox Header="Rete di livellazione">

                        <DataGrid x:Name="GridRete"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True">

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Da" Binding="{Binding From}" Width="*"/>
                                <DataGridTextColumn Header="A" Binding="{Binding To}" Width="*"/>
                                <DataGridTextColumn Header="Δh" Binding="{Binding Dh}" Width="*"/>
                                <DataGridTextColumn Header="Distanza" Binding="{Binding Dist}" Width="*"/>

                            </DataGrid.Columns>

                        </DataGrid>

                    </GroupBox>

                    <!-- LOG -->
                    <GroupBox Header="Log" Grid.Row="1" Margin="0,10,0,0">

                        <TextBox x:Name="LogBox"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"/>

                    </GroupBox>

                </Grid>

            </Grid>

            <!-- ================= COMP ================= -->
            <Grid x:Name="GridComp" Visibility="Collapsed">

                <GroupBox Header="Risultati compensazione" Margin="10">

                    <DataGrid x:Name="GridResult"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Nodo" Binding="{Binding Nodo}" Width="*"/>
                            <DataGridTextColumn Header="Quota" Binding="{Binding Quota}" Width="*"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </GroupBox>

            </Grid>

        </Grid>

        <!-- ================= STATUS ================= -->
        <Border Grid.Row="2" Background="#DDD">

            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Margin="10"
                       Text="Pronto"/>

        </Border>

    </Grid>
</Window>